# ─────────────────────────────────────────────────────────────
# PULSE Network Configuration
# ─────────────────────────────────────────────────────────────
# Set your PC's LAN IP here. All apps will read from this.
#
# Find your IP:
#   Windows:  ipconfig → Wi-Fi adapter → IPv4 Address
#   Mac:      ipconfig getifaddr en0
#   Linux:    hostname -I
#
# All phones and browsers must be on the SAME Wi-Fi network.
# ─────────────────────────────────────────────────────────────

API_HOST=192.168.1.42
API_PORT=9000
