# ─────────────────────────────────────────────────────────────
# PULSE Network Configuration
# ─────────────────────────────────────────────────────────────
#
# OPTION A – Cloud (Render / Railway / etc.)
#   Set API_BASE_URL to your deployed backend URL.
#   API_HOST and API_PORT are ignored when API_BASE_URL is set.
#
# OPTION B – Local LAN
#   Comment out API_BASE_URL and set API_HOST + API_PORT.
#   Find your IP:
#     Windows:  ipconfig → Wi-Fi adapter → IPv4 Address
#     Mac:      ipconfig getifaddr en0
#     Linux:    hostname -I
# ─────────────────────────────────────────────────────────────

API_BASE_URL=https://pulse-ni99.onrender.com

