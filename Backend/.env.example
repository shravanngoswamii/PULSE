# ─────────────────────────────────────────────────────────────
# PULSE Backend – Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values for your machine.
# NEVER commit .env to git.

# Host / port the uvicorn server listens on.
# Use 0.0.0.0 so the server is reachable from simulators, emulators,
# and physical devices on the same Wi-Fi network.
# Use 127.0.0.1 if you only need localhost access.
HOST=0.0.0.0
PORT=9000

# Secret key used to sign JWT tokens. Change this in production!
PULSE_SECRET_KEY=pulse-hackathon-secret-key-2026

# SQLite database file path (relative to Backend/)
DATABASE_URL=sqlite:///./pulse.db
