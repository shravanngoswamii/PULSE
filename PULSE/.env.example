# ─────────────────────────────────────────────────────────────
# PULSE Flutter App – Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and set API_HOST to match YOUR machine.
#
# ┌─────────────────────────────────────────────────────────┐
# │  Where to run / which host to use                       │
# ├─────────────────────────────────────────────────────────┤
# │  iOS Simulator (Mac)        → localhost                 │
# │  Android Emulator           → 10.0.2.2                  │
# │  Physical device (Wi-Fi)    → your Mac's LAN IP         │
# │    e.g. 192.168.1.42  (run `ipconfig getifaddr en0`)    │
# └─────────────────────────────────────────────────────────┘

API_HOST=localhost
API_PORT=9000
